{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "RUNE",
  "scopeName": "source.rune",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#governance-decisions" },
    { "include": "#governance-keywords" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#operators" },
    { "include": "#functions" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.rune",
          "match": "//.*$"
        },
        {
          "name": "comment.block.rune",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.rune",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.rune",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.rune",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*([eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.hex.rune",
          "match": "\\b0[xX][0-9a-fA-F_]+\\b"
        },
        {
          "name": "constant.numeric.octal.rune",
          "match": "\\b0[oO][0-7_]+\\b"
        },
        {
          "name": "constant.numeric.binary.rune",
          "match": "\\b0[bB][01_]+\\b"
        },
        {
          "name": "constant.numeric.integer.rune",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },
    "governance-decisions": {
      "patterns": [
        {
          "name": "keyword.control.decision.rune",
          "match": "\\b(permit|deny|escalate|quarantine)\\b"
        }
      ]
    },
    "governance-keywords": {
      "patterns": [
        {
          "name": "keyword.other.governance.rune",
          "match": "\\b(policy|rule|attest|audit|secure_zone|unsafe_ffi|capability|effect|perform|handle|require|satisfies)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.rune",
          "match": "\\b(if|else|match|while|for|in|return|break|continue)\\b"
        },
        {
          "name": "keyword.declaration.rune",
          "match": "\\b(fn|let|mut|const|struct|enum|type|impl|trait|pub|mod|use|where|with)\\b"
        },
        {
          "name": "constant.language.boolean.rune",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "keyword.operator.logical.rune",
          "match": "\\b(not|and|or)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "entity.name.type.primitive.rune",
          "match": "\\b(Int|Float|Bool|String|Unit)\\b"
        },
        {
          "name": "entity.name.type.rune",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.rune",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.logical.rune",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.arithmetic.rune",
          "match": "(\\+|-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.assignment.rune",
          "match": "(\\+=|-=|\\*=|=)"
        },
        {
          "name": "keyword.operator.arrow.rune",
          "match": "(->|=>)"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.rune",
          "match": "\\b([a-z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.rune",
          "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
